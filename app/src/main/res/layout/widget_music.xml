<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingStart="14dp"
    android:paddingEnd="14dp"
    android:paddingTop="10dp"
    android:paddingBottom="10dp">

    <!-- Album Cover -->
    <FrameLayout
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:background="@drawable/widget_cover_circle_bg">

        <ImageView
            android:id="@+id/widget_cover"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:layout_gravity="center"
            android:scaleType="centerCrop"
            android:contentDescription="封面" />
    </FrameLayout>

    <!-- Song Info -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="8dp"
        android:orientation="vertical">

        <TextView
            android:id="@+id/widget_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="未在播放"
            android:textColor="#FFFFFFFF"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_artist"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="BiliMusic"
            android:textColor="#99FFFFFF"
            android:textSize="12sp" />
    </LinearLayout>

    <!-- Controls -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <!-- Previous -->
        <ImageView
            android:id="@+id/widget_prev"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/widget_control_bg"
            android:padding="8dp"
            android:scaleType="centerInside"
            android:src="@android:drawable/ic_media_previous"
            android:contentDescription="上一首"
            android:tint="#CCFFFFFF" />

        <!-- Play/Pause -->
        <ImageView
            android:id="@+id/widget_play"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginStart="6dp"
            android:layout_marginEnd="6dp"
            android:background="@drawable/widget_button_circle"
            android:padding="12dp"
            android:scaleType="centerInside"
            android:src="@android:drawable/ic_media_play"
            android:contentDescription="播放"
            android:tint="#FFFFFFFF" />

        <!-- Next -->
        <ImageView
            android:id="@+id/widget_next"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/widget_control_bg"
            android:padding="8dp"
            android:scaleType="centerInside"
            android:src="@android:drawable/ic_media_next"
            android:contentDescription="下一首"
            android:tint="#CCFFFFFF" />
    </LinearLayout>

</LinearLayout>
